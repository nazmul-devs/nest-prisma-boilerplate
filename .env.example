# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
APP_NAME="IATA Accounting SaaS"
PORT=5000
NODE_ENV=development # development, production, test
API_PREFIX=api/v1

# ==========================================
# SECURITY & CORS
# ==========================================
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# JWT Auth
JWT_SECRET="YOUR_SUPER_SECRET_RANDOM_STRING_HERE"
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET="YOUR_REFRESH_TOKEN_SECRET_HERE"
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# DATABASE (PostgreSQL & Prisma)
# ==========================================
DATABASE_URL="postgresql://username:password@localhost:5432/iata_acc_db?schema=public"

# ==========================================
# CACHE & QUEUE (Redis)
# ==========================================
REDIS_URL="redis://localhost:6379"

# ==========================================
# EMAIL CONFIGURATION (SMTP)
# ==========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=nariaholidays.dev@gmail.com
EMAIL_PASSWORD="your_google_app_password" 
EMAIL_FROM="IATA SaaS <noreply@iata-saas.com>"

# ==========================================
# FILE STORAGE (S3 - optional for reports/IATA files)
# ==========================================
# IATA-র বিশাল বড় ফাইলগুলো সার্ভারে না রেখে ক্লাউডে রাখা ভালো
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=

# ==========================================
# THIRD PARTY INTEGRATIONS (Amadeus/Sabre)
# ==========================================
